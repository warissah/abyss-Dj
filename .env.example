# Copy this file to .env (in the same folder as server.js) and fill in real values.
# .env is gitignored, so your secrets will NOT be committed.

# ---- Google Gemini ----
GEMINI_API_KEY=
# Optional override. Default is gemini-2.5-flash-lite.
GEMINI_MODEL=gemini-2.5-flash-lite

# ---- Server ----
PORT=3000
# If the share QR picks a VPN IP (e.g. 10.66.x) and your phone can't connect,
# set this to your Mac's Wi‑Fi IPv4 (System Settings → Network → Wi‑Fi → Details).
PUBLIC_LAN_IP=
